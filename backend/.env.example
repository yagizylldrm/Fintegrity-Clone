# Fintegrity Backend - Environment Variables
# Copy this file to .env and adjust values as needed

# JWT Authentication
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Blockchain (Hardhat Local Node)
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545

# Smart Contract Addresses (update after deployment)
# Run: cd blockchain && npx hardhat run scripts/deploy.ts --network localhost
FINTEGRITY_CORE_ADDRESS=0x_DEPLOY_CIKTISINDAKI_ADRES
SMART_AGREEMENTS_ADDRESS=0x_DEPLOY_CIKTISINDAKI_ADRES
